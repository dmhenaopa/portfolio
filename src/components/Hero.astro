---
import Badge from "./Badge.astro";
import GitHubIcon from "../icons/GitHub.astro";
import GitLabIcon from "../icons/GitLab.astro";
import LinkedInIcon from "../icons/LinkedIn.astro";
import InstagramIcon from "../icons/Instagram.astro";
import SocialMediaPill from "./SocialMediaPill.astro";
---

<h1
  class="text-green-bonsai text-3xl sm:text-4xl md:text-5xl font-bold flex flex-row flex-wrap gap-x-4 gap-y-2 pb-6 md:pb-10"
>
  Hi! I'm Diana Henao <a
    href="https://www.linkedin.com/in/dimhenaopa/"
    target="_blank"
    rel="noopener noreferrer"
    class="flex justify-center items-center"
    ><Badge>Available for hire</Badge></a
  >
</h1>
<h2 class="text-black-darkest-black text-lg sm:text-xl md:text-2xl opacity-80">
  QA & Technical Product Professional based in Bogotá, Colombia. Strong in
  quality, systems understanding, and cross-functional work. Currently expanding
  toward development and data.
</h2>
<nav class="flex flex-wrap gap-x-3 gap-y-2 mt-6">
  <SocialMediaPill href="https://www.linkedin.com/in/dimhenaopa/">
    <LinkedInIcon class="size-4" />
    LinkedIn
  </SocialMediaPill>
  <SocialMediaPill href="https://github.com/dmhenaopa">
    <GitHubIcon class="size-4" />
    GitHub
  </SocialMediaPill>
  <SocialMediaPill href="https://gitlab.com/dm.henao">
    <GitLabIcon class="size-4" />
    GitLab
  </SocialMediaPill>
  <SocialMediaPill href="https://www.instagram.com/dianalupe.doodles">
    <InstagramIcon class="size-4" />
    Instagram
  </SocialMediaPill>
</nav>
